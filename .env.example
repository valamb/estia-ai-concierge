# =============================================================
# ESTIA — AI Multimodal Hotel Concierge Assistant
# Environment Variables Template
#
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# =============================================================

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.3

# ----- Application -----
APP_NAME=ESTIA
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ----- API Server -----
HOST=0.0.0.0
PORT=8000

# ----- ChromaDB Vector Store -----
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=estia_knowledge

# ----- Knowledge Base -----
KNOWLEDGE_BASE_PATH=./knowledge

# ----- Language -----
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,el

# ----- RAG Settings -----
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# ----- Hotel Properties -----
# Comma-separated list of active properties
ACTIVE_PROPERTIES=porto_elounda,elounda_mare,elounda_peninsula
